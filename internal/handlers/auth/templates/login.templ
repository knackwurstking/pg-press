package templates

import (
	"github.com/knackwurstking/pg-press/internal/templates/components"
	"github.com/knackwurstking/pg-press/internal/templates/components/button"
	"github.com/knackwurstking/pg-press/internal/templates/components/dialog"
	"github.com/knackwurstking/pg-press/internal/templates/components/form"
	"github.com/knackwurstking/pg-press/internal/templates/components/input"
	"github.com/knackwurstking/pg-press/internal/urlb"
)

type PageProps struct {
	FormData map[string]string
}

templ Page(p PageProps) {
	@components.Layout(components.LayoutProps{
		PageTitle:   "PG Presse | Login",
		AppBarTitle: "Login",
	}) {
		@components.Page() {
			@apiKeyDialog(p.FormData["api-key"], p.FormData["invalid-api-key"])
			<script>
				document.querySelector("#login-dialog").showModal();
			</script>
		}
	}
}

templ apiKeyDialog(apiKey, invalidApiKey string) {
	@dialog.Dialog(dialog.Props{
		ID:               "login-dialog",
		DisableClickAway: true,
		DisableESC:       true,
		Open:             true,
	}) {
		<form action={ urlb.Login("", nil) } method="post">
			@dialog.Content(dialog.ContentProps{
				HideCloseButton: true,
			}) {
				@dialog.Title() {
					Login
				}
				@form.Item() {
					@form.Label(form.LabelProps{
						For: "api-key",
					}) {
						API-Schlüssel
					}
					{{ hasError := invalidApiKey == "true" }}
					@input.Input(input.Props{
						ID:          "api-key",
						Name:        "api-key",
						Type:        "text",
						Placeholder: "API-Schlüssel",
						Value:       apiKey,
						HasError:    hasError,
						Required:    true,
					})
					if hasError {
						@form.Message(form.MessageProps{
							Variant: form.MessageVariantError,
						}) {
							Ungültiger API-Schlüssel
						}
					}
				}
				@dialog.Footer() {
					@button.Button(button.Props{
						Type: button.TypeSubmit,
					}) {
						Anmelden
					}
				}
			}
		</form>
	}
}
