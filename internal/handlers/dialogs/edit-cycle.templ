package dialogs

import (
	"github.com/knackwurstking/pg-press/internal/errors"
	"github.com/knackwurstking/pg-press/internal/shared"
	"github.com/knackwurstking/pg-press/internal/templates/components/templui/button"
	"github.com/knackwurstking/pg-press/internal/templates/components/templui/dialog"
	"github.com/knackwurstking/pg-press/internal/urlb"
)

type CycleFormData struct {
	ToolID shared.EntityID
	Tools  []*shared.Tool

	PressID shared.EntityID
	Presses []*shared.Press

	Stop        shared.UnixMilli
	PressCycles int64
}

type CycleDialogProps struct {
	CycleFormData
	Open, OOB bool
	Error     []*errors.InputError
}

templ NewCycleDialog(props ...CycleDialogProps) {
	{{
		prop := CycleDialogProps{}
		if len(props) > 0 {
			prop = props[0]
		}

		attr := templ.Attributes{}
		if prop.OOB {
			attr["hx-swap-oob"] = "true"
		}
	}}
	@dialog.Dialog(dialog.Props{
		ID:               NewCycleDialogID,
		DisableClickAway: true,
		DisableESC:       true,
		Open:             prop.Open,
		Attributes:       attr,
	}) {
		@dialog.Content(dialog.ContentProps{
			Class: "overflow-auto max-h-[90vh]", // TODO: For now, this will fix the overflow issue
		}) {
			@dialog.Header() {
				Neuer Zyklus
			}
			@renderDialogError(prop.Error)
			<form
				hx-post={ urlb.DialogEditCycle(0, prop.ToolID, false) }
				hx-trigger="submit"
				hx-on::response-error="alert(event.detail.xhr.responseText)"
				enctype="multipart/form-data"
				class="space-y-4"
			>
				@formCycleToolChange(prop.ToolID, prop.Tools, prop.Error...)
				@formPressSelection(prop.PressID, prop.Presses, prop.Error...)
				@formDate(prop.Stop, formProps{"Ablesedatum", "stop", true}, prop.Error...)
				@formCycles(prop.PressCycles, prop.Error...)
				@dialog.Footer() {
					@button.Button(button.Props{
						Type: button.TypeSubmit,
					}) {
						Erstellen
					}
				}
			</form>
		}
	}
}

templ EditCycleDialog(cycleID shared.EntityID, props ...CycleDialogProps) {
	{{
		prop := CycleDialogProps{}
		if len(props) > 0 {
			prop = props[0]
		}

		attr := templ.Attributes{}
		if prop.OOB {
			attr["hx-swap-oob"] = "true"
		}

		toolChangeMode := len(prop.Tools) > 0
	}}
	@dialog.Dialog(dialog.Props{
		ID:               EditCycleDialogID,
		DisableClickAway: true,
		DisableESC:       true,
		Open:             prop.Open,
		Attributes:       attr,
	}) {
		@dialog.Content(dialog.ContentProps{
			Class: "overflow-auto max-h-[90vh]", // TODO: For now, this will fix the overflow issue
		}) {
			@dialog.Header() {
				Zyklus bearbeiten
			}
			@renderDialogError(prop.Error)
			<form
				hx-post={ urlb.DialogEditCycle(cycleID, prop.ToolID, toolChangeMode) }
				hx-trigger="submit"
				hx-on::response-error="alert(event.detail.xhr.responseText)"
				enctype="multipart/form-data"
				class="space-y-4"
			>
				if toolChangeMode {
					@formCycleToolChange(prop.ToolID, prop.Tools, prop.Error...)
				}
				@formPressSelection(prop.PressID, prop.Presses, prop.Error...)
				@formDate(prop.Stop, formProps{"Ablesedatum", "stop", true}, prop.Error...)
				@formCycles(prop.PressCycles, prop.Error...)
				@dialog.Footer() {
					@button.Button(button.Props{
						Type: button.TypeSubmit,
					}) {
						Aktualisieren
					}
				}
			</form>
		}
	}
}
