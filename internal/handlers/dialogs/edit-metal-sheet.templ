templ metalSheetContentPositionTop(data UpperMetalSheetFormData, ierrs ...*errors.InputError) {
	@formTileHeight(data.TileHeight, ierrs...)
	@formSheets(data.Value, ierrs...)
}

templ metalSheetContentPositionBottom(data LowerMetalSheetFormData, ierrs ...*errors.InputError) {
	@formMachineType(data.Identifier, ierrs...)
	@formTileHeight(data.TileHeight, ierrs...)
	@formStf(data.STF, ierrs...)
	@formStfMax(data.STFMax, ierrs...)
	@formMarkeHeight(data.MarkeHeight, ierrs...)
	@formSheets(data.Value, ierrs...)
}

templ formTileHeight(tileHeight float64, ierrs ...*errors.InputError) {
	@form.Item() {
		@form.Label(form.LabelProps{
			For: "tile_height",
		}) {
			Stärke (mm)
		}
		@input.Input(input.Props{
			ID:       "tile_height",
			Name:     "tile_height",
			Type:     input.TypeNumber,
			Required: true,
			Attributes: templ.Attributes{
				"step": "0.1",
			},
			Value:    fmt.Sprintf("%.1f", tileHeight),
			HasError: hasInputError(ierrs, "tile_height"),
		})
		@renderFormError(ierrs, "tile_height")
	}
}

templ formSheets(value float64, ierrs ...*errors.InputError) {
	@form.Item() {
		@form.Label(form.LabelProps{
			For: "value",
