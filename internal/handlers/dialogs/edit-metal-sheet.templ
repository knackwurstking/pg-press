package dialogs

import (
	"fmt"

	"github.com/knackwurstking/pg-press/internal/components/button"
	"github.com/knackwurstking/pg-press/internal/components/dialog"
	"github.com/knackwurstking/pg-press/internal/components/form"
	"github.com/knackwurstking/pg-press/internal/components/input"
	"github.com/knackwurstking/pg-press/internal/errors"
	"github.com/knackwurstking/pg-press/internal/shared"
	"github.com/knackwurstking/pg-press/internal/urlb"
)

type UpperMetalSheetFormData struct {
	TileHeight float64
	Value      float64
}

type LowerMetalSheetFormData struct {
	Identifier  shared.MachineType
	TileHeight  float64
	STF         float64
	STFMax      float64
	MarkeHeight int
	Value       float64
}

type UpperMetalSheetDialogProps struct {
	UpperMetalSheetFormData

	ToolID       shared.EntityID
	ToolPosition shared.Slot

	Open, OOB bool
	Error     []*errors.InputError
}

type LowerMetalSheetDialogProps struct {
	LowerMetalSheetFormData

	ToolID       shared.EntityID
	ToolPosition shared.Slot

	Open, OOB bool
	Error     []*errors.InputError
}

templ NewUpperMetalSheetDialog(props ...UpperMetalSheetDialogProps) {
	{{
		prop := UpperMetalSheetDialogProps{}
		if len(props) > 0 {
			prop = props[0]
		}

		attr := templ.Attributes{}
		if prop.OOB {
			attr["hx-swap-oob"] = "true"
		}
	}}
	@dialog.Dialog(dialog.Props{
		ID:               NewUpperMetalSheetDialogID,
		DisableClickAway: true,
		DisableESC:       true,
		Open:             prop.Open,
		Attributes:       attr,
	}) {
		@dialog.Content(dialog.ContentProps{
			Class: "overflow-auto max-h-[90vh]", // TODO: For now, this will fix the overflow issue
		}) {
			@dialog.Header() {
				Obere Blechliste Erstellen
			}
			@renderDialogError(prop.Error)
			<form
				hx-post={ urlb.DialogEditMetalSheet(0, prop.ToolID, prop.ToolPosition) }
				hx-trigger="submit"
				hx-on::response-error="alert(event.detail.xhr.responseText)"
				enctype="multipart/form-data"
				class="space-y-4"
			>
				@metalSheetContentPositionTop(prop.UpperMetalSheetFormData, prop.Error...)
				@dialog.Footer() {
					@button.Button(button.Props{
						Type: button.TypeSubmit,
					}) {
						Erstellen
					}
				}
			</form>
		}
	}
}

